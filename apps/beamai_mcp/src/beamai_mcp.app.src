{application, beamai_mcp, [
    {description, "MCP (Model Context Protocol) Client and Server"},
    {vsn, "1.0.0"},
    {registered, [
        beamai_mcp_sup,
        beamai_mcp_client_sup,
        beamai_mcp_server_sup
    ]},
    {mod, {beamai_mcp_app, []}},
    {applications, [
        kernel,
        stdlib,
        jsx,
        beamai_core
    ]},
    %% 可选依赖：
    %% - cowboy: 仅在使用 beamai_mcp_cowboy_handler（server 端）时需要
    %% - gun: HTTP/SSE 传输的唯一后端；仅使用 stdio 传输时可不启动
    {optional_applications, [cowboy, gun]},
    {env, [
        {default_timeout, 30000},
        {tool_call_timeout, 60000},
        {init_timeout, 10000}
    ]},
    {modules, [
        %% Application
        beamai_mcp_app,
        beamai_mcp_sup,
        %% Types
        beamai_mcp_types,
        beamai_mcp_jsonrpc,
        %% Transport (Client)
        beamai_mcp_transport,
        beamai_mcp_transport_stdio,
        %% HTTP/SSE 传输：Gun 后端（HTTP/2）
        beamai_mcp_transport_sse_gun,
        beamai_mcp_transport_http_gun,
        %% Client
        beamai_mcp_client,
        beamai_mcp_client_sup,
        beamai_mcp_client_registry,
        %% Server
        beamai_mcp_server,
        beamai_mcp_server_sup,
        beamai_mcp_session_registry,
        beamai_mcp_handler,
        beamai_mcp_cowboy_handler,
        %% Adapter (MCP 工具 ↔ agent 工具转换)
        beamai_mcp_adapter
    ]},
    {licenses, ["Apache-2.0"]},
    {links, []}
]}.
