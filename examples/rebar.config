{erl_opts, [debug_info]}.

{src_dirs, ["src"]}.

%% beamai 依赖通过 ERL_LIBS 环境变量提供
%% 使用方式:
%%   ERL_LIBS=../_build/default/lib:../_build/default/checkouts rebar3 compile
%%   ERL_LIBS=../_build/default/lib:../_build/default/checkouts rebar3 shell
%% 或直接用 examples/Makefile: make compile / make shell

{deps, [
    {jsx, "3.1.0"},
    {hackney, "1.20.1"},
    {meck, "0.9.2"}
]}.

{dialyzer, [
    {plt_extra_apps, [
        beamai_core, beamai_llm,
        beamai_agent, beamai_tools
    ]}
]}.

{shell, [
    {apps, [beamai, hackney]}
]}.
